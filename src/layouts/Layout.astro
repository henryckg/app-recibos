---
import "@/styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Sistema de Recibos - Alfaparf Milano",
	description = "Plataforma de registro de recibos de pago para vendedores Alfaparf Milano"
} = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" /> -->
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-linear-to-br from-slate-50 via-white to-slate-100">
		<slot />
	</body>
</html>
